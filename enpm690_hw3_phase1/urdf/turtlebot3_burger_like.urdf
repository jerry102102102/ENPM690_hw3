<?xml version="1.0"?>
<robot name="turtlebot3_burger_like">
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.35 0.35 0.35 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.45 0.0 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.11" length="0.08"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.08 0 0.06" rpy="0 0 0"/>
  </joint>

  <link name="laser_frame">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.04"/>
      </geometry>
      <material name="orange"/>
    </visual>
  </link>
</robot>
